{
  "name": "@mrsf/monaco-mrsf",
  "version": "0.4.5",
  "description": "Monaco editor plugin for rendering and editing Sidemark/MRSF (Markdown Review Sidecar Format) review comments",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": {
        "import": "./dist/browser.js",
        "types": "./dist/browser.d.ts"
      },
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser.js",
      "types": "./dist/browser.d.ts"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node ../sync-types.mjs && node esbuild.config.mjs",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "cp ../../LICENSE . && npm run build && npm test",
    "postpublish": "rm -f LICENSE"
  },
  "keywords": [
    "monaco",
    "monaco-editor",
    "markdown",
    "review",
    "sidecar",
    "mrsf",
    "sidemark",
    "comments",
    "annotation",
    "editor-plugin"
  ],
  "license": "MIT",
  "author": "Wictor Wilén (https://github.com/wictorwilen)",
  "homepage": "https://github.com/wictorwilen/MRSF/tree/main/plugins/monaco#readme",
  "bugs": {
    "url": "https://github.com/wictorwilen/MRSF/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wictorwilen/MRSF.git",
    "directory": "plugins/monaco"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@mrsf/cli": "file:../../cli"
  },
  "peerDependencies": {
    "monaco-editor": ">=0.45 <1"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.10",
    "esbuild": "^0.27.3",
    "jsdom": "^26.1.0",
    "monaco-editor": "^0.52.2",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}