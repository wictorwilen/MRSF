{
  "name": "@mrsf/mcp",
  "version": "0.3.0",
  "description": "MCP server for the Markdown Review Sidecar Format (MRSF)",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "bin": {
    "mrsf-mcp": "./dist/bin.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "test": "vitest run",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "cp ../LICENSE . && npm run build",
    "postpublish": "rm -f LICENSE"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "markdown",
    "review",
    "sidecar",
    "mrsf",
    "sidemark",
    "ai",
    "llm",
    "copilot",
    "claude",
    "cursor",
    "agent",
    "agent-skill"
  ],
  "license": "MIT",
  "author": "Wictor Wilén (https://github.com/wictorwilen)",
  "homepage": "https://github.com/wictorwilen/MRSF/tree/main/mcp#readme",
  "bugs": {
    "url": "https://github.com/wictorwilen/MRSF/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wictorwilen/MRSF.git",
    "directory": "mcp"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@mrsf/cli": "file:../cli",
    "@types/node": "^22.13.10",
    "esbuild": "^0.27.3",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18",
    "zod": "^3.25.67"
  }
}
